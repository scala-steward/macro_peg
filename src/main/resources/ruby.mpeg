// Ruby grammar for MacroPEG ParserGenerator
// Target: generate a plain Scala recursive-descent parser that passes 100% of the Ruby corpus
//
// This file is processed by ParserGenerator to produce GeneratedRubyParser.scala.
// Action blocks use pattern matching on the `~` case class generated alongside the parser.

%package com.github.kmizu.macro_peg.ruby;
%import com.github.kmizu.macro_peg.ruby.RubyAst._;
%import scala.util.Try;
%object GeneratedRubyParser;
%start program;

%raw heredocLiteral {
    // Parse a Ruby heredoc literal: <<[-~]?(quote?DELIM quote?)
    // Consumes the start line (<<DELIM + rest of line), heredoc body lines, and terminator line.
    // Returns ("", posAfterTerminator) on success, None on failure.
    var p = pos
    if (p + 2 > input.length || input.charAt(p) != '<' || input.charAt(p + 1) != '<') return None
    p += 2
    // Optional flag: - or ~
    val indented = if (p < input.length && (input.charAt(p) == '-' || input.charAt(p) == '~')) { p += 1; true } else false
    // Optional quote character
    val qc: Char = if (p < input.length && (input.charAt(p) == '"' || input.charAt(p) == '\'' || input.charAt(p) == '`')) {
      val c = input.charAt(p); p += 1; c
    } else '\u0000'
    // Read delimiter
    val delimStart = p
    if (qc != '\u0000') {
      // Quoted: read until matching close quote (or newline = error)
      while (p < input.length && input.charAt(p) != qc && input.charAt(p) != '\n') p += 1
      if (p >= input.length || input.charAt(p) != qc) return None
    } else {
      // Unquoted: identifier characters
      while (p < input.length && (input.charAt(p).isLetterOrDigit || input.charAt(p) == '_')) p += 1
    }
    val delim = input.substring(delimStart, p)
    if (delim.isEmpty) return None
    if (qc != '\u0000') p += 1 // consume close quote
    // Skip rest of start line (including the terminating \n)
    while (p < input.length && input.charAt(p) != '\n' && input.charAt(p) != '\r') p += 1
    if (p < input.length && input.charAt(p) == '\r') p += 1
    if (p < input.length && input.charAt(p) == '\n') p += 1
    // Scan subsequent lines for the terminator
    while (p < input.length) {
      val lineStart = p
      var ts = p
      if (indented) while (ts < input.length && (input.charAt(ts) == ' ' || input.charAt(ts) == '\t')) ts += 1
      if (input.startsWith(delim, ts)) {
        val after = ts + delim.length
        if (after >= input.length || input.charAt(after) == '\n' || input.charAt(after) == '\r' || input.charAt(after) == ';') {
          var end = after
          if (end < input.length && input.charAt(end) == '\r') end += 1
          if (end < input.length && input.charAt(end) == '\n') end += 1
          return Some((StringLiteral(""), end))
        }
      }
      // Advance to next line
      while (p < input.length && input.charAt(p) != '\n') p += 1
      if (p < input.length) p += 1
      if (p == lineStart) return None // guard: no progress (EOF edge case)
    }
    None
};

// Helper for O(n) scanning of percent literal bodies (avoids O(n^2) list building)
%helper {
  private def _scanBalancedBody(input: String, pos: Int, open: Char, close: Char): Option[(Any, Int)] = {
    if (pos >= input.length || input.charAt(pos) != open) return None
    var p = pos + 1; var depth = 1
    while (p < input.length && depth > 0) {
      val c = input.charAt(p)
      if (c == '\\' && p + 1 < input.length) p += 2
      else if (c == open) { depth += 1; p += 1 }
      else if (c == close) { depth -= 1; p += 1 }
      else p += 1
    }
    if (depth == 0) Some(("", p)) else None
  }
  private def _scanSimpleBody(input: String, pos: Int, delim: Char): Option[(Any, Int)] = {
    if (pos >= input.length || input.charAt(pos) != delim) return None
    var p = pos + 1
    while (p < input.length && input.charAt(p) != delim) {
      if (input.charAt(p) == '\\' && p + 1 < input.length) p += 2
      else p += 1
    }
    if (p < input.length) Some(("", p + 1)) else None
  }
};

%raw percentBodyBraces { _scanBalancedBody(input, pos, '{', '}') };
%raw percentBodyParens { _scanBalancedBody(input, pos, '(', ')') };
%raw percentBodyBrackets { _scanBalancedBody(input, pos, '[', ']') };
%raw percentBodyAngles { _scanBalancedBody(input, pos, '<', '>') };
%raw percentBodySimplePipe { _scanSimpleBody(input, pos, '|') };
%raw percentBodySimplePercent { _scanSimpleBody(input, pos, '%') };
%raw percentBodySimpleDoubleQuote { _scanSimpleBody(input, pos, '"') };
%raw percentBodySimpleSingleQuote { _scanSimpleBody(input, pos, '\'') };
%raw percentBodySimpleSlash { _scanSimpleBody(input, pos, '/') };
%raw percentBodySimpleColon { _scanSimpleBody(input, pos, ':') };
%raw percentBodySimpleExcl { _scanSimpleBody(input, pos, '!') };
%raw percentBodySimpleComma { _scanSimpleBody(input, pos, ',') };
%raw percentBodySimpleSemicolon { _scanSimpleBody(input, pos, ';') };
%raw percentBodySimpleDash { _scanSimpleBody(input, pos, '-') };
%raw percentBodySimpleUnderscore { _scanSimpleBody(input, pos, '_') };
%raw percentBodySimpleEquals { _scanSimpleBody(input, pos, '=') };
%raw percentBodySimplePlus { _scanSimpleBody(input, pos, '+') };



// ── Higher-order combinators ─────────────────────────────────────────────

SepBy0(elem, sep) =
  (elem (sep elem)*)?
  => { case Some(h ~ t) => h :: t.asInstanceOf[List[Any]].map({ case _ ~ v => v })
       case None => List.empty[Any] } ;

SepBy1(elem, sep) =
  elem (sep elem)*
  => { case h ~ t => h :: t.asInstanceOf[List[Any]].map({ case _ ~ v => v }) } ;

// Block body: parse statements until stop is ahead (stop not consumed)
blockStatementsUntil(stop) =
  (!(stop) statement statementSep*)*
  => { stmts => stmts.asInstanceOf[List[Any]].map { case _ ~ stmt ~ _ => stmt.asInstanceOf[Statement] } } ;

// ── Lexical primitives ───────────────────────────────────────────────────

@memo
horizontalSpaceChar =
  (" " / "\t" / "\r") => { _ => () } ;

@memo
newlineChar =
  "\n" => { _ => () } ;

lineContinuation =
  "\\\n" => { _ => () } ;

comment =
  "#" (!"\n" .)* => { _ => () } ;

blockComment =
  "=begin" (!"=end" .)* "=end" => { _ => () } ;

@memo
inlineSpacing =
  (horizontalSpaceChar / lineContinuation / comment / blockComment)* => { _ => () } ;

@memo
spacing =
  (horizontalSpaceChar / newlineChar / lineContinuation / comment / blockComment)* => { _ => () } ;

spacing1 =
  (horizontalSpaceChar / comment / blockComment)+ => { _ => () } ;

lineBreak =
  inlineSpacing "\n" inlineSpacing => { _ => () } ;

@memo
statementSep =
  inlineSpacing (";" / "\n") spacing
  => { _ => () } ;

@memo
identStart =
  [a-zA-Z_] => { c => c.toString } ;

@memo
identCont =
  [a-zA-Z0-9_] => { c => c.toString } ;

@memo
identifierRaw =
  identStart identCont*
  => { case s ~ cs => s.toString + cs.asInstanceOf[List[Any]].mkString } ;

@memo
reservedWord =
  ( "begin" / "end" / "do" / "if" / "unless" / "while" / "until"
  / "for" / "in" / "return" / "yield" / "and" / "or" / "not"
  / "true" / "false" / "nil" / "self" / "class" / "module" / "def"
  / "then" / "elsif" / "else" / "case" / "when" / "rescue" / "ensure"
  / "retry" / "break" / "next" / "alias" / "defined?"
  ) !identCont => { case kw ~ _ => kw } ;

identifierNoSpace =
  !(reservedWord) identifierRaw
  => { case _ ~ name => name.asInstanceOf[String] } ;

@memo
@label("identifier")
identifier =
  identifierNoSpace inlineSpacing
  => { case name ~ _ => name.asInstanceOf[String] } ;

@memo
constNameNoSpace =
  [A-Z] identCont*
  => { case h ~ t => h.toString + t.asInstanceOf[List[Any]].mkString } ;

@memo
constName =
  constNameNoSpace inlineSpacing
  => { case name ~ _ => name.asInstanceOf[String] } ;

instanceVarNameRaw =
  "@" identifierRaw
  => { case _ ~ name => "@" + name.asInstanceOf[String] } ;

classVarNameRaw =
  "@@" identifierRaw
  => { case _ ~ name => "@@" + name.asInstanceOf[String] } ;

@memo
instanceVarName =
  instanceVarNameRaw inlineSpacing
  => { case name ~ _ => name.asInstanceOf[String] } ;

@memo
classVarName =
  classVarNameRaw inlineSpacing
  => { case name ~ _ => name.asInstanceOf[String] } ;

globalVarSpecial =
  ( "$!" / "$?" / "$@" / "$&" / "$`" / "$'" / "$+" / "$~"
  / "$/" / "$\\" / "$," / "$." / "$;" / "$<" / "$>" / "$_"
  / "$:" / "$=" / "$*" / "$$"
  ) => { s => s } ;

globalVarDash =
  "$-" [a-zA-Z0-9_]
  => { case _ ~ c => "$-" + c.toString } ;

globalVarNumeric =
  "$" [0-9]+
  => { case _ ~ ds => "$" + ds.asInstanceOf[List[Any]].mkString } ;

globalVarNamed =
  "$" identifierRaw
  => { case _ ~ name => "$" + name.asInstanceOf[String] } ;

@memo
globalVarName =
  (globalVarSpecial / globalVarDash / globalVarNumeric / globalVarNamed) inlineSpacing
  => { case n ~ _ => n.asInstanceOf[String] } ;

constPathSegment =
  "::" constNameNoSpace => { case _ ~ n => n.asInstanceOf[String] } ;

constPathNoSpace =
  constNameNoSpace constPathSegment*
  => { case h ~ t => h.asInstanceOf[String] :: t.asInstanceOf[List[Any]].map(_.asInstanceOf[String]) } ;

constPathWithRoot =
  "::" constNameNoSpace ("::" constNameNoSpace)*
  => { _ => List.empty[String] } ;

@memo
constPath =
  (constPathNoSpace / constPathWithRoot) inlineSpacing
  => { case p ~ _ => p } ;

symbolOperatorName =
  ( "**" / "===" / "<=>" / "=~" / "!~" / "!=" / "=="
  / "<<" / ">>" / "[]=" / "[]" / "<=" / ">=" / "<" / ">"
  / "+@" / "-@" / "+" / "-" / "*" / "/" / "%" / "&" / "|" / "^" / "~" / "!" / "`"
  ) => { s => s } ;

methodSuffixChar =
  ("?" / ("!" !("=" / "~")) / ("=" !("=" / ">" / "~")))
  => { s => s } ;

methodIdentifierRaw =
  ( (identifierRaw methodSuffixChar) /
    (!(reservedWord) identifierRaw)
  ) => { v => v } ;

// ── Token helpers ────────────────────────────────────────────────────────

assignEq =
  "=" !("=" / ">" / "~") inlineSpacing => { _ => "=" } ;

labelColon =
  ":" !":" inlineSpacing => { _ => ":" } ;

// ── Numeric literals ─────────────────────────────────────────────────────

decimalDigitsRaw =
  [0-9] [0-9_]*
  => { _ => "" } ;

binaryDigitsRaw =
  [01] [01_]*
  => { _ => "" } ;

octalDigitsRaw =
  [0-7] [0-7_]*
  => { _ => "" } ;

hexDigitsRaw =
  [0-9a-fA-F] [0-9a-fA-F_]*
  => { _ => "" } ;

integerLiteralCore =
  ( ("0" [bB] binaryDigitsRaw) /
    ("0" [oO] octalDigitsRaw) /
    ("0" [dD] decimalDigitsRaw) /
    ("0" [xX] hexDigitsRaw) /
    decimalDigitsRaw
  ) => { _ => "" } ;

numericSuffix =
  ("ri" / "ir" / "r" / "i") => { s => s } ;

floatExponent =
  [eE] ("+" / "-")? [0-9]+ => { _ => "" } ;

floatLiteralCore =
  ( (decimalDigitsRaw "." decimalDigitsRaw floatExponent?) /
    (decimalDigitsRaw floatExponent)
  ) => { _ => "" } ;

@memo
floatLiteral =
  floatLiteralCore numericSuffix? !identCont inlineSpacing
  => { _ => FloatLiteral(0.0) } ;

@memo
@label("integer literal")
integerLiteral =
  integerLiteralCore !("." [0-9]) numericSuffix? !identCont inlineSpacing
  => { _ => IntLiteral(BigInt(0)) } ;

// ── Character literal ────────────────────────────────────────────────────

charLiteral =
  "?" !(" " / "\t" / "\n") ("\\" . / .) inlineSpacing
  => { _ => StringLiteral("") } ;

// ── String escapes and interpolation ────────────────────────────────────

escapedChar =
  "\\" . => { case _ ~ c => c.toString } ;

interpolationChunkInner =
  ( ("\"" (!("\"") .)* "\"") /
    ("'" (!"'" .)* "'") /
    ("{" interpolationChunkInner* "}") /
    (!"}" .)
  ) => { _ => "" } ;

interpolationSegment =
  "#{" interpolationChunkInner* "}"
  => { _ => "" } ;

// ── Double-quoted string ─────────────────────────────────────────────────

dqStringChar =
  !("\"" / "\\" / "#{") .
  => { c => c.toString } ;

@memo
@label("string literal")
stringLiteral =
  "\"" (escapedChar / interpolationSegment / dqStringChar)* "\"" inlineSpacing
  => { _ => StringLiteral("") } ;

// ── Single-quoted string ─────────────────────────────────────────────────

sqStringChar =
  !("'" / "\\") . => { c => c.toString } ;

escapedSqChar =
  "\\" ("'" / "\\") => { case _ ~ c => c.toString } ;

@memo
singleQuotedStringLiteral =
  "'" (escapedSqChar / sqStringChar)* "'" inlineSpacing
  => { _ => StringLiteral("") } ;

// ── Backtick literal ─────────────────────────────────────────────────────

backtickChar =
  !("`" / "\\" / "#{") . => { c => c.toString } ;

backtickLiteral =
  "`" (escapedChar / interpolationSegment / backtickChar)* "`" inlineSpacing
  => { _ => StringLiteral("") } ;

// ── Percent literal bodies (parameterized by delimiter) ──────────────────

// Concrete recursive percent-body rules (no infinite macro expansion)
percentBodyBraces =
  "{" (("\\" .) / percentBodyBraces / !"}" .)* "}"
  => { _ => "" } ;

percentBodyParens =
  "(" (("\\" .) / percentBodyParens / !")" .)* ")"
  => { _ => "" } ;

percentBodyBrackets =
  "[" (("\\" .) / percentBodyBrackets / !"]" .)* "]"
  => { _ => "" } ;

percentBodyAngles =
  "<" (("\\" .) / percentBodyAngles / !">" .)* ">"
  => { _ => "" } ;

percentBodySimplePipe =
  "|" (("\\" .) / !"|" .)* "|" => { _ => "" } ;

percentBodySimplePercent =
  "%" (("\\" .) / !"%" .)* "%" => { _ => "" } ;

percentBodySimpleDoubleQuote =
  "\"" (("\\" .) / !"\"" .)* "\"" => { _ => "" } ;

percentBodySimpleSingleQuote =
  "'" (("\\" .) / !"'" .)* "'" => { _ => "" } ;

percentBodySimpleSlash =
  "/" (("\\" .) / !"/" .)* "/" => { _ => "" } ;

percentBodySimpleColon =
  ":" (("\\" .) / !":" .)* ":" => { _ => "" } ;

percentBodySimpleExcl =
  "!" (("\\" .) / !"!" .)* "!" => { _ => "" } ;

percentBodySimpleComma =
  "," (("\\" .) / !"," .)* "," => { _ => "" } ;

percentBodySimpleSemicolon =
  ";" (("\\" .) / !";" .)* ";" => { _ => "" } ;

percentBodySimpleDash =
  "-" (("\\" .) / !"-" .)* "-" => { _ => "" } ;

percentBodySimpleUnderscore =
  "_" (("\\" .) / !"_" .)* "_" => { _ => "" } ;

percentBodySimpleEquals =
  "=" (("\\" .) / !"=" .)* "=" => { _ => "" } ;

percentBodySimplePlus =
  "+" (("\\" .) / !"+" .)* "+" => { _ => "" } ;

percentBody =
  ( percentBodyBraces /
    percentBodyParens /
    percentBodyBrackets /
    percentBodyAngles /
    percentBodySimplePipe /
    percentBodySimplePercent /
    percentBodySimpleDoubleQuote /
    percentBodySimpleSingleQuote /
    percentBodySimpleSlash /
    percentBodySimpleColon /
    percentBodySimpleExcl /
    percentBodySimpleComma /
    percentBodySimpleSemicolon /
    percentBodySimpleDash /
    percentBodySimpleUnderscore /
    percentBodySimpleEquals /
    percentBodySimplePlus
  ) => { _ => "" } ;

percentQuotedStringLiteral =
  "%" !("r" / "w" / "W" / "i" / "I" / "s" / "x") ("q" / "Q")? percentBody inlineSpacing
  => { _ => StringLiteral("") } ;

percentWordArray =
  "%" ("w" / "W") percentBody inlineSpacing
  => { _ => ArrayLiteral(List.empty) } ;

percentSymbolArray =
  "%" ("i" / "I") percentBody inlineSpacing
  => { _ => ArrayLiteral(List.empty) } ;

percentSymbolLiteralExpr =
  "%s" percentBody inlineSpacing
  => { _ => SymbolLiteral("", UnknownSpan) } ;

percentRegex =
  "%r" percentBody [a-zA-Z]* inlineSpacing
  => { _ => StringLiteral("") } ;

percentCommand =
  "%x" percentBody inlineSpacing
  => { _ => StringLiteral("") } ;

// ── Regex literal ────────────────────────────────────────────────────────

escapedRegexChar =
  "\\" . => { _ => "" } ;

plainRegexChar =
  !("/" / "\\" / "#{") . => { c => c.toString } ;

regexBodyChars =
  (escapedRegexChar / interpolationSegment / plainRegexChar)*
  => { _ => "" } ;

regexLiteral =
  percentRegex /
  ("/" !(" " / "\t") regexBodyChars "/" [a-zA-Z]* inlineSpacing
   => { _ => StringLiteral("") }) ;

// ── Symbol literals ──────────────────────────────────────────────────────

symbolNamePart =
  ( symbolOperatorName /
    classVarNameRaw /
    instanceVarNameRaw /
    globalVarNamed /
    methodIdentifierRaw /
    constNameNoSpace /
    (reservedWord => { r => r })
  ) => { v => v } ;

@memo
symbolLiteral =
  ":" !":" (
    ( "\"" (escapedChar / interpolationSegment / dqStringChar)* "\"" ) /
    ( "'" (escapedSqChar / sqStringChar)* "'" ) /
    symbolNamePart
  ) inlineSpacing
  => { _ => SymbolLiteral("", UnknownSpan) } ;

labelNameNoSpace =
  (!(reservedWord) identifierRaw / reservedWord)
  => { v => v } ;

labelSymbol =
  labelNameNoSpace ":" !":" inlineSpacing
  => { _ => SymbolLiteral("", UnknownSpan) } ;

quotedLabelSymbol =
  (stringLiteral / symbolLiteral) labelColon spacing
  => { _ => SymbolLiteral("", UnknownSpan) } ;

// ── Variable/const expressions ───────────────────────────────────────────

@memo
selfExpr =
  "self" !identCont inlineSpacing => { _ => SelfExpr() } ;

boolLiteral =
  ( ("true" !identCont inlineSpacing) /
    ("false" !identCont inlineSpacing)
  ) => { _ => BoolLiteral(true) } ;

nilLiteral =
  "nil" !identCont inlineSpacing => { _ => NilLiteral() } ;

@memo
localVarExpr =
  identifier => { name => LocalVar(name.asInstanceOf[String]) } ;

@memo
instanceVarExpr =
  instanceVarName => { name => InstanceVar(name.asInstanceOf[String]) } ;

@memo
classVarExpr =
  classVarName => { name => ClassVar(name.asInstanceOf[String]) } ;

@memo
globalVarExpr =
  globalVarName => { name => GlobalVar(name.asInstanceOf[String]) } ;

@memo
variable =
  instanceVarExpr / classVarExpr / globalVarExpr / localVarExpr ;

@memo
constRef =
  constPath => { path => ConstRef(path.asInstanceOf[List[String]]) } ;

// ── Parenthesized expression ─────────────────────────────────────────────

parenExprInner =
  statementSep* (expr (statementSep+ expr)*)? statementSep*
  => { _ => NilLiteral() } ;

parenExpr =
  "(" spacing parenExprInner ")" inlineSpacing
  => { _ => NilLiteral() } ;

// ── Array literal ────────────────────────────────────────────────────────

arrayElem =
  ( ("**" spacing expr) /
    ("*" spacing expr) /
    (quotedLabelSymbol spacing expr) /
    (labelSymbol spacing expr) /
    (expr spacing "=>" spacing expr) /
    expr
  ) => { _ => NilLiteral() } ;

@memo
arrayLiteral =
  "[" spacing (arrayElem (spacing "," spacing arrayElem)* (spacing ",")? spacing)? "]" inlineSpacing
  => { _ => ArrayLiteral(List.empty) } ;

// ── Hash literal ─────────────────────────────────────────────────────────

hashEntry =
  ( ("**" spacing expr) /
    (quotedLabelSymbol spacing expr) /
    (labelSymbol spacing expr) /
    (expr spacing "=>" spacing expr)
  ) => { _ => NilLiteral() } ;

@memo
hashLiteral =
  "{" spacing (hashEntry (spacing "," spacing hashEntry)* (spacing ",")? spacing)? "}" inlineSpacing
  => { _ => HashLiteral(List.empty) } ;

// ── Formal parameters ────────────────────────────────────────────────────

keywordParam =
  labelNameNoSpace ":" !":" spacing expr?
  => { _ => "" } ;

destructuredParam =
  "(" spacing formalParam (spacing "," spacing formalParam)* (spacing ",")? spacing ")"
  => { _ => "()" } ;

formalParam =
  ( "..." /
    ("**" spacing ("nil" !identCont / identifier)?) /
    ("*" spacing ("nil" !identCont / identifier)?) /
    ("&" spacing ("nil" !identCont / identifier)?) /
    keywordParam /
    destructuredParam /
    (identifier (spacing "=" spacing expr)?)
  ) => { _ => "" } ;

params =
  "(" spacing (formalParam (spacing "," spacing formalParam)* (spacing ",")? spacing)? ")" inlineSpacing
  => { _ => List.empty[String] } ;

bareParams =
  formalParam (inlineSpacing "," inlineSpacing formalParam)+
  => { _ => List.empty[String] } ;

// ── Block parameters ─────────────────────────────────────────────────────

blockFormalParam =
  ( "..." /
    ("**" spacing ("nil" !identCont / identifier)?) /
    ("*" spacing ("nil" !identCont / identifier)?) /
    ("&" spacing ("nil" !identCont / identifier)?) /
    keywordParam /
    destructuredParam /
    identifier
  ) => { _ => "" } ;

blockLocalVar =
  identifier => { _ => "" } ;

blockParams =
  "|" spacing (blockFormalParam (spacing "," spacing blockFormalParam)* (spacing ",")? spacing)?
  (";" spacing blockLocalVar (spacing "," spacing blockLocalVar)*)? spacing "|" inlineSpacing
  => { _ => List.empty[String] } ;

// ── Rescue/ensure stop conditions ────────────────────────────────────────

rescueStop =
  ("rescue" !identCont spacing / "else" !identCont spacing / "ensure" !identCont spacing / "end" !identCont spacing)
  => { _ => () } ;

doBlockStop =
  ("rescue" !identCont spacing / "else" !identCont spacing / "ensure" !identCont spacing / "end" !identCont spacing)
  => { _ => () } ;

endKeyword =
  "end" !identCont spacing => { _ => () } ;

rescueClause =
  "rescue" !identCont spacing
  (expr (spacing "," spacing expr)*)?
  ("=>" spacing variable spacing)?
  statementSep*
  blockStatementsUntil(rescueStop)
  statementSep*
  => { _ => RescueClause(List.empty, None, List.empty) } ;

// ── Lambda literal ───────────────────────────────────────────────────────

lambdaLiteral =
  "->" inlineSpacing (params / (parenExpr => { _ => List.empty[String] }))? spacing blockLiteral
  => { _ => LambdaLiteral(List.empty, List.empty) } ;

// ── Block literals ───────────────────────────────────────────────────────

doBlock =
  "do" !identCont spacing
  statementSep*
  blockParams?
  statementSep*
  blockStatementsUntil(doBlockStop)
  statementSep*
  rescueClause*
  statementSep*
  ("else" !identCont spacing statementSep* blockStatementsUntil(doBlockStop) statementSep*)?
  ("ensure" !identCont spacing statementSep* blockStatementsUntil(endKeyword) statementSep*)?
  endKeyword
  => { _ => Block(List.empty, List.empty) } ;

braceBlockStop =
  "}" => { _ => () } ;

braceBlock =
  "{" inlineSpacing statementSep* blockParams? statementSep*
  blockStatementsUntil(braceBlockStop)
  statementSep* spacing "}" inlineSpacing
  => { _ => Block(List.empty, List.empty) } ;

blockLiteral =
  doBlock / braceBlock ;

// ── Call argument expressions ────────────────────────────────────────────

callArgItem =
  ( "..." /
    ("&" spacing (symbolLiteral / expr)) /
    ("**" spacing expr) /
    ("*" spacing expr) /
    (quotedLabelSymbol spacing expr) /
    (labelSymbol spacing expr) /
    (expr spacing "=>" spacing expr) /
    expr
  ) => { _ => NilLiteral() } ;

callArgs =
  "(" spacing (callArgItem (spacing "," spacing callArgItem)* (spacing ",")? spacing)? ")" inlineSpacing
  => { _ => List.empty[Expr] } ;

commandArgStop =
  ("if" !identCont / "unless" !identCont / "while" !identCont / "until" !identCont / "rescue" !identCont)
  => { _ => () } ;

commandArgItem =
  ( ("&" spacing (symbolLiteral / expr)) /
    ("**" spacing expr) /
    ("*" spacing expr) /
    (quotedLabelSymbol spacing expr) /
    (labelSymbol spacing expr) /
    (expr spacing "=>" spacing expr) /
    expr
  ) => { _ => NilLiteral() } ;

commandArgs =
  !(commandArgStop) commandArgItem (inlineSpacing "," spacing commandArgItem)*
  => { _ => List.empty[Expr] } ;

subscriptArgs =
  "[" spacing (callArgItem (spacing "," spacing callArgItem)* (spacing ",")? spacing)? "]" inlineSpacing
  => { _ => List.empty[Expr] } ;

// ── Member access / dot separator ────────────────────────────────────────

dotSep =
  ( (inlineSpacing ("&." / "::" / ".") inlineSpacing) /
    (inlineSpacing "\n" inlineSpacing ("&." / "::" / ".") inlineSpacing)
  ) => { _ => "." } ;

// ── Primary expression ───────────────────────────────────────────────────

@memo
@label("primary expression")
primaryExpr =
  ( lambdaLiteral /
    singletonClassExpr /
    beginExpr /
    defExprForm /
    returnExpr /
    yieldExpr /
    ifExpr /
    unlessExpr /
    caseExpr /
    selfExpr /
    boolLiteral /
    nilLiteral /
    constRef /
    variable /
    floatLiteral /
    integerLiteral /
    charLiteral /
    stringLiteral /
    singleQuotedStringLiteral /
    backtickLiteral /
    percentCommand /
    percentQuotedStringLiteral /
    percentSymbolLiteralExpr /
    percentWordArray /
    percentSymbolArray /
    regexLiteral /
    symbolLiteral /
    arrayLiteral /
    heredocLiteral /
    hashLiteral /
    parenExpr
  ) ;

// ── Call suffixes ────────────────────────────────────────────────────────

methodName =
  ( symbolOperatorName /
    constNameNoSpace /
    methodIdentifierRaw /
    ("private" !identCont / "public" !identCont / "protected" !identCont /
     "ruby2_keywords" !identCont / "class" !identCont / "def" !identCont /
     "begin" !identCont / "end" !identCont / "for" !identCont / "self" !identCont)
  ) inlineSpacing => { _ => "" } ;

callSuffix =
  ( (dotSep methodName callArgs?) /
    (dotSep callArgs) /
    subscriptArgs /
    (inlineSpacing blockLiteral)
  ) => { _ => () } ;

functionCallExpr =
  methodIdentifierRaw inlineSpacing callArgs
  => { _ => NilLiteral() } ;

commandCallExpr =
  methodIdentifierRaw spacing1 commandArgs
  => { _ => NilLiteral() } ;

@memo
postfixExpr =
  (functionCallExpr / commandCallExpr / primaryExpr)
  callSuffix*
  => { case base ~ _ => base.asInstanceOf[Expr] } ;

// ── Operator precedence hierarchy ─────────────────────────────────────────

@memo
powerExpr =
  postfixExpr ("**" spacing powerExpr)?
  => { case base ~ opt => opt.asInstanceOf[Option[Any]] match { case None => base.asInstanceOf[Expr]; case Some(_ ~ rhs) => BinaryOp(base.asInstanceOf[Expr], "**", rhs.asInstanceOf[Expr]) } } ;

unaryOpSym =
  ("not" !identCont spacing / "!" / "~" / "-" / "+" / "*")
  => { v => v match { case (op ~ _) ~ _ => op.asInstanceOf[String]; case op => op.asInstanceOf[String] } } ;

@memo
unaryExpr =
  (unaryOpSym spacing unaryExpr / powerExpr)
  => { v => v match { case (op ~ _) ~ e => UnaryOp(op.asInstanceOf[String], e.asInstanceOf[Expr]); case e => e.asInstanceOf[Expr] } } ;

@memo
mulDivExpr =
  unaryExpr (("*" !"=" / "/" !("=" / "}") / "%" !"=") spacing unaryExpr)*
  => { case base ~ ops => ops.asInstanceOf[List[Any]].foldLeft(base.asInstanceOf[Expr]) { (acc, item) => { val ((op ~ _) ~ _) ~ rhs = item; BinaryOp(acc, op.asInstanceOf[String], rhs.asInstanceOf[Expr]) } } } ;

@memo
addSubExpr =
  mulDivExpr (("+" !("=" / "@") / "-" !("=" / "@" / ">")) spacing mulDivExpr)*
  => { case base ~ ops => ops.asInstanceOf[List[Any]].foldLeft(base.asInstanceOf[Expr]) { (acc, item) => { val ((op ~ _) ~ _) ~ rhs = item; BinaryOp(acc, op.asInstanceOf[String], rhs.asInstanceOf[Expr]) } } } ;

@memo
shiftExpr =
  addSubExpr (("<<" / ">>") !"=" spacing addSubExpr)*
  => { case base ~ ops => ops.asInstanceOf[List[Any]].foldLeft(base.asInstanceOf[Expr]) { (acc, item) => { val ((op ~ _) ~ _) ~ rhs = item; BinaryOp(acc, op.asInstanceOf[String], rhs.asInstanceOf[Expr]) } } } ;

@memo
bitAndExpr =
  shiftExpr ("&" !("&" / "=") spacing shiftExpr)*
  => { case base ~ ops => ops.asInstanceOf[List[Any]].foldLeft(base.asInstanceOf[Expr]) { (acc, item) => { val ((op ~ _) ~ _) ~ rhs = item; BinaryOp(acc, op.asInstanceOf[String], rhs.asInstanceOf[Expr]) } } } ;

@memo
bitOrExpr =
  bitAndExpr (("|" !("=" / "|") / "^" !"=") spacing bitAndExpr)*
  => { case base ~ ops => ops.asInstanceOf[List[Any]].foldLeft(base.asInstanceOf[Expr]) { (acc, item) => { val ((op ~ _) ~ _) ~ rhs = item; BinaryOp(acc, op.asInstanceOf[String], rhs.asInstanceOf[Expr]) } } } ;

@memo
relationalExpr =
  bitOrExpr (("<=" / ">=" / "<" !("<" / "=") / ">" !(">" / "=")) spacing bitOrExpr)*
  => { case base ~ ops => ops.asInstanceOf[List[Any]].foldLeft(base.asInstanceOf[Expr]) { (acc, item) => item match { case ((op ~ _) ~ _) ~ rhs => BinaryOp(acc, op.asInstanceOf[String], rhs.asInstanceOf[Expr]); case (op ~ _) ~ rhs => BinaryOp(acc, op.asInstanceOf[String], rhs.asInstanceOf[Expr]) } } } ;

@memo
equalityExpr =
  relationalExpr (("===" / "<=>" / "=~" / "!~" / "!=" / "==") spacing relationalExpr)*
  => { case base ~ ops => ops.asInstanceOf[List[Any]].foldLeft(base.asInstanceOf[Expr]) { (acc, item) => { val (op ~ _) ~ rhs = item; BinaryOp(acc, op.asInstanceOf[String], rhs.asInstanceOf[Expr]) } } } ;

rangeOp =
  ("..." / "..") => { s => s } ;

@memo
rangeExpr =
  ( (rangeOp spacing equalityExpr) /
    (equalityExpr (rangeOp spacing equalityExpr?)?)
  ) => { v => v match { case (op ~ _) ~ rhs => RangeExpr(NilLiteral(), rhs.asInstanceOf[Expr], op == "..."); case base ~ None => base.asInstanceOf[Expr]; case base ~ Some(v2) => { val (op ~ _) ~ endOpt = v2; RangeExpr(base.asInstanceOf[Expr], endOpt.asInstanceOf[Option[Any]].map(_.asInstanceOf[Expr]).getOrElse(NilLiteral()), op == "...") } } } ;

@memo
andExpr =
  rangeExpr ("&&" !"=" spacing rangeExpr)*
  => { case base ~ ops => ops.asInstanceOf[List[Any]].foldLeft(base.asInstanceOf[Expr]) { (acc, item) => { val ((op ~ _) ~ _) ~ rhs = item; BinaryOp(acc, op.asInstanceOf[String], rhs.asInstanceOf[Expr]) } } } ;

@memo
orExpr =
  andExpr ("||" !"=" spacing andExpr)*
  => { case base ~ ops => ops.asInstanceOf[List[Any]].foldLeft(base.asInstanceOf[Expr]) { (acc, item) => { val ((op ~ _) ~ _) ~ rhs = item; BinaryOp(acc, op.asInstanceOf[String], rhs.asInstanceOf[Expr]) } } } ;

// Pattern expressions
inPatternPrimary =
  ( constRef /
    variable /
    symbolLiteral /
    stringLiteral /
    singleQuotedStringLiteral /
    nilLiteral /
    boolLiteral /
    integerLiteral /
    floatLiteral /
    ("^" spacing postfixExpr) /
    parenExpr /
    ("[" spacing (inPatternListElem (spacing "," spacing inPatternListElem)* (spacing ",")? spacing)? "]" inlineSpacing) /
    ("{" spacing (inPatternHashEntry (spacing "," spacing inPatternHashEntry)* (spacing ",")? spacing)? "}" inlineSpacing) /
    (constRef "(" spacing (inPatternListElem (spacing "," spacing inPatternListElem)* (spacing ",")? spacing)? ")" inlineSpacing) /
    ("*" spacing (("nil" !identCont inlineSpacing) / variable)?)
  ) => { _ => NilLiteral() } ;

inPatternHashEntry =
  ( ("**" spacing (("nil" !identCont inlineSpacing) / variable)?) /
    (quotedLabelSymbol spacing inPatternPrimary) /
    (labelSymbol spacing inPatternPrimary) /
    (labelSymbol) /
    (expr spacing "=>" spacing inPatternPrimary)
  ) => { _ => NilLiteral() } ;

inPatternListElem =
  ("*" spacing (("nil" !identCont inlineSpacing) / variable)? / inPatternOrExpr)
  => { _ => NilLiteral() } ;

inPatternOrExpr =
  inPatternPrimary (spacing "|" spacing inPatternPrimary)*
  => { _ => NilLiteral() } ;

inPatternExpr =
  inPatternOrExpr (spacing "=>" spacing variable)?
  (spacing ("if" !identCont / "unless" !identCont) spacing expr)?
  => { _ => NilLiteral() } ;

inMatchExpr =
  orExpr ("in" !identCont spacing inPatternExpr)?
  => { case base ~ _ => base.asInstanceOf[Expr] } ;

@memo
conditionalExpr =
  inMatchExpr (spacing "?" spacing conditionalExpr spacing ":" !":" spacing conditionalExpr)?
  => { case base ~ _ => base.asInstanceOf[Expr] } ;

// ── Assignment expressions ─────────────────────────────────────────────────

compoundAssignOp =
  ("<<=" / ">>=" / "+=" / "-=" / "*=" / "/=" / "%=" / "&=" / "|=" / "^=" / "**=")
  => { s => s } ;

assignableTarget =
  (instanceVarExpr / classVarExpr / globalVarExpr / constRef / localVarExpr)
  => { v => v.asInstanceOf[Expr] } ;

assignValueExpr =
  ("*" spacing conditionalExpr / conditionalExpr) (spacing "," spacing ("*" spacing conditionalExpr / conditionalExpr))*
  => { _ => NilLiteral() } ;

@memo
chainedAssignRhs =
  ( (postfixExpr dotSep methodName assignEq spacing chainedAssignRhs) /
    (postfixExpr dotSep methodName compoundAssignOp spacing chainedAssignRhs) /
    (postfixExpr dotSep methodName ("||=" / "&&=") spacing chainedAssignRhs) /
    (assignableTarget subscriptArgs assignEq spacing chainedAssignRhs) /
    (assignableTarget subscriptArgs compoundAssignOp spacing chainedAssignRhs) /
    (assignableTarget subscriptArgs ("||=" / "&&=") spacing chainedAssignRhs) /
    (assignableTarget compoundAssignOp spacing chainedAssignRhs) /
    (assignableTarget ("||=" / "&&=") spacing chainedAssignRhs) /
    (assignableTarget assignEq spacing chainedAssignRhs) /
    conditionalExpr
  ) => { v => if (v.isInstanceOf[Expr]) v.asInstanceOf[Expr] else NilLiteral() } ;

multiAssignElem =
  ( ("*" spacing assignableTarget?) /
    ("(" spacing multiAssignElem (spacing "," spacing multiAssignElem)* (spacing ",")? spacing ")") /
    assignableTarget
  ) => { _ => "" } ;

multiAssignTargets =
  ( (multiAssignElem (spacing "," spacing multiAssignElem)+ (spacing ",")?) /
    (multiAssignElem spacing ",") /
    ("*" spacing assignableTarget?)
  ) => { _ => List.empty[String] } ;

assignmentExpr =
  ( (postfixExpr dotSep methodName assignEq spacing assignValueExpr) /
    (postfixExpr dotSep methodName compoundAssignOp spacing chainedAssignRhs) /
    (postfixExpr dotSep methodName ("||=" / "&&=") spacing chainedAssignRhs) /
    (assignableTarget subscriptArgs assignEq spacing assignValueExpr) /
    (assignableTarget subscriptArgs compoundAssignOp spacing chainedAssignRhs) /
    (assignableTarget subscriptArgs ("||=" / "&&=") spacing chainedAssignRhs) /
    (multiAssignTargets assignEq spacing assignValueExpr) /
    (assignableTarget compoundAssignOp spacing chainedAssignRhs) /
    (assignableTarget ("||=" / "&&=") spacing chainedAssignRhs) /
    (assignableTarget assignEq spacing assignValueExpr) /
    conditionalExpr
  ) => { v => if (v.isInstanceOf[Expr]) v.asInstanceOf[Expr] else NilLiteral() } ;

@memo
@label("expression")
expr =
  assignmentExpr (("and" !identCont / "or" !identCont) spacing assignmentExpr)*
  => { case base ~ _ => base.asInstanceOf[Expr] } ;

// ── Inline expression-forms of compound statements ────────────────────────

beginExpr =
  "begin" !identCont spacing
  statementSep*
  blockStatementsUntil(rescueStop / endKeyword)
  statementSep*
  rescueClause*
  statementSep*
  ("else" !identCont spacing statementSep* blockStatementsUntil(doBlockStop) statementSep*)?
  ("ensure" !identCont spacing statementSep* blockStatementsUntil(endKeyword) statementSep*)?
  endKeyword
  => { _ => NilLiteral() } ;

defExprForm =
  defStmt => { _ => NilLiteral() } ;

returnExpr =
  "return" !identCont inlineSpacing
  (!(commandArgStop) expr (spacing "," spacing expr)*)?
  => { _ => NilLiteral() } ;

yieldExpr =
  "yield" !identCont inlineSpacing callArgs?
  => { _ => NilLiteral() } ;

singletonClassExpr =
  "class" !identCont spacing "<<" spacing expr statementSep*
  blockStatementsUntil(endKeyword)
  statementSep* endKeyword
  => { _ => NilLiteral() } ;

ifElsifElse =
  ( ("elsif" !identCont spacing expr
     ("then" !identCont spacing / inlineSpacing statementSep+)
     statementSep*
     blockStatementsUntil("elsif" !identCont spacing / "else" !identCont spacing / endKeyword)
     statementSep*
     ifElsifElse) /
    ("else" !identCont spacing statementSep*
     blockStatementsUntil(endKeyword) statementSep*)
  )?
  => { _ => List.empty[Statement] } ;

ifExpr =
  "if" !identCont spacing expr
  ("then" !identCont spacing / inlineSpacing statementSep+ / inlineSpacing ";")
  statementSep*
  blockStatementsUntil("elsif" !identCont spacing / "else" !identCont spacing / endKeyword)
  statementSep*
  ifElsifElse
  endKeyword
  => { _ => NilLiteral() } ;

unlessExpr =
  "unless" !identCont spacing expr
  ("then" !identCont spacing / inlineSpacing statementSep+ / inlineSpacing ";")
  statementSep*
  blockStatementsUntil("else" !identCont spacing / endKeyword)
  statementSep*
  ("else" !identCont spacing statementSep* blockStatementsUntil(endKeyword) statementSep*)?
  endKeyword
  => { _ => NilLiteral() } ;

whenClause =
  ("when" !identCont / "in" !identCont) spacing
  inPatternExpr (spacing "," spacing inPatternExpr)*
  (inlineSpacing (";" / "then" !identCont) spacing)?
  statementSep*
  blockStatementsUntil("when" !identCont spacing / "in" !identCont spacing / "else" !identCont spacing / endKeyword)
  statementSep*
  => { _ => WhenClause(List.empty, List.empty) } ;

caseExpr =
  "case" !identCont spacing expr? statementSep*
  whenClause+
  ("else" !identCont spacing statementSep* blockStatementsUntil(endKeyword) statementSep*)?
  endKeyword
  => { _ => NilLiteral() } ;

// ── Statement-level constructs ─────────────────────────────────────────────

modifierSuffix =
  ( ("if" !identCont spacing expr) /
    ("unless" !identCont spacing expr) /
    ("while" !identCont spacing expr) /
    ("until" !identCont spacing expr) /
    ("rescue" !identCont spacing expr)
  ) => { _ => () } ;

returnStmt =
  "return" !identCont inlineSpacing
  (!(commandArgStop) expr (spacing "," spacing expr)*)?
  => { _ => Return(None) } ;

retryStmt =
  "retry" !identCont inlineSpacing => { _ => Retry() } ;

breakStmt =
  "break" !identCont inlineSpacing (!(commandArgStop) expr (spacing "," spacing expr)*)?
  => { _ => ExprStmt(NilLiteral()) } ;

nextStmt =
  "next" !identCont inlineSpacing (!(commandArgStop) expr (spacing "," spacing expr)*)?
  => { _ => ExprStmt(NilLiteral()) } ;

yieldStmt =
  "yield" !identCont inlineSpacing callArgs?
  => { _ => ExprStmt(NilLiteral()) } ;

aliasNamePart =
  (symbolLiteral / (symbolOperatorName inlineSpacing) / (methodIdentifierRaw inlineSpacing) / globalVarName)
  => { _ => SymbolLiteral("", UnknownSpan) } ;

aliasStmt =
  "alias" !identCont spacing aliasNamePart spacing aliasNamePart
  => { _ => ExprStmt(NilLiteral()) } ;

defReceiverPart =
  ( ("(" spacing expr spacing ")") /
    (constPathNoSpace inlineSpacing) /
    ("self" !identCont inlineSpacing) /
    ("nil" !identCont inlineSpacing) /
    ("true" !identCont inlineSpacing) /
    ("false" !identCont inlineSpacing) /
    instanceVarName / classVarName / globalVarName /
    identifier
  ) => { _ => "" } ;

defMethodNamePart =
  ( symbolOperatorName /
    ("`" (!"`" .)* "`") /
    methodIdentifierRaw /
    ("private" !identCont / "public" !identCont / "protected" !identCont /
     "ruby2_keywords" !identCont / "class" !identCont / "def" !identCont /
     "begin" !identCont / "end" !identCont / "for" !identCont / "self" !identCont)
  ) inlineSpacing => { _ => "" } ;

defNamePart =
  (defReceiverPart "." spacing defMethodNamePart / defMethodNamePart)
  => { _ => "" } ;

@label("method definition")
@cut
defStmt =
  ("private" !identCont spacing / "public" !identCont spacing / "protected" !identCont spacing / "ruby2_keywords" !identCont spacing)?
  "def" !identCont spacing
  defNamePart
  (params / (spacing1 bareParams))?
  spacing
  ( (assignEq spacing expr) /
    ( statementSep*
      blockStatementsUntil(rescueStop / endKeyword)
      statementSep*
      rescueClause*
      statementSep*
      ("else" !identCont spacing statementSep* blockStatementsUntil(doBlockStop) statementSep*)?
      ("ensure" !identCont spacing statementSep* blockStatementsUntil(endKeyword) statementSep*)?
      endKeyword
    )
  )
  => { _ => Def("", List.empty, List.empty) } ;

singletonClassStmt =
  "class" !identCont spacing "<<" spacing expr statementSep*
  blockStatementsUntil(endKeyword)
  statementSep* endKeyword callSuffix*
  => { _ => SingletonClassDef(NilLiteral(), List.empty) } ;

@label("class definition")
@cut
classStmt =
  "class" !identCont spacing constPath
  ("<" !"<" spacing expr)?
  statementSep*
  blockStatementsUntil(endKeyword)
  statementSep* endKeyword
  => { _ => ClassDef("", List.empty) } ;

@label("module definition")
@cut
moduleStmt =
  "module" !identCont spacing constPath
  statementSep*
  blockStatementsUntil(endKeyword)
  statementSep* endKeyword
  => { _ => ModuleDef("", List.empty) } ;

@label("while statement")
@cut
whileStmt =
  "while" !identCont spacing expr
  (("do" !identCont / "then" !identCont) spacing / inlineSpacing statementSep+)?
  statementSep*
  blockStatementsUntil(endKeyword)
  statementSep* endKeyword
  => { _ => WhileExpr(NilLiteral(), List.empty) } ;

@label("until statement")
@cut
untilStmt =
  "until" !identCont spacing expr
  (("do" !identCont / "then" !identCont) spacing / inlineSpacing statementSep+)?
  statementSep*
  blockStatementsUntil(endKeyword)
  statementSep* endKeyword
  => { _ => UntilExpr(NilLiteral(), List.empty) } ;

forBindingTarget =
  (multiAssignTargets / assignableTarget)
  => { _ => "" } ;

@label("for statement")
@cut
forStmt =
  "for" !identCont spacing forBindingTarget spacing "in" !identCont spacing expr
  (("do" !identCont / "then" !identCont) spacing / inlineSpacing statementSep+)?
  statementSep*
  blockStatementsUntil(endKeyword)
  statementSep* endKeyword
  => { _ => ForIn("", NilLiteral(), List.empty) } ;

@label("begin block")
@cut
beginStmt =
  "begin" !identCont spacing
  statementSep*
  blockStatementsUntil(rescueStop / endKeyword)
  statementSep*
  rescueClause*
  statementSep*
  ("else" !identCont spacing statementSep* blockStatementsUntil(doBlockStop) statementSep*)?
  ("ensure" !identCont spacing statementSep* blockStatementsUntil(endKeyword) statementSep*)?
  endKeyword
  => { _ => ExprStmt(NilLiteral()) } ;

@label("if statement")
@cut
ifStmt =
  "if" !identCont spacing expr
  ("then" !identCont spacing / inlineSpacing statementSep+ / inlineSpacing ";")
  statementSep*
  blockStatementsUntil("elsif" !identCont spacing / "else" !identCont spacing / endKeyword)
  statementSep*
  ifElsifElse
  endKeyword
  => { _ => IfExpr(NilLiteral(), List.empty, List.empty) } ;

@label("unless statement")
@cut
unlessStmt =
  "unless" !identCont spacing expr
  ("then" !identCont spacing / inlineSpacing statementSep+ / inlineSpacing ";")
  statementSep*
  blockStatementsUntil("else" !identCont spacing / endKeyword)
  statementSep*
  ("else" !identCont spacing statementSep* blockStatementsUntil(endKeyword) statementSep*)?
  endKeyword
  => { _ => UnlessExpr(NilLiteral(), List.empty, List.empty) } ;

@label("case statement")
@cut
caseStmt =
  "case" !identCont spacing expr? statementSep*
  whenClause+
  ("else" !identCont spacing statementSep* blockStatementsUntil(endKeyword) statementSep*)?
  endKeyword
  => { _ => CaseExpr(None, List.empty, List.empty) } ;

rightwardAssignStmt =
  conditionalExpr spacing "=>" spacing inPatternExpr
  => { _ => ExprStmt(NilLiteral()) } ;

exprStatement =
  expr (spacing1 commandArgs)?
  inlineSpacing
  => { case (e ~ _) ~ _ => ExprStmt(e.asInstanceOf[Expr]) } ;

@memo
@label("statement")
statement =
  ( returnStmt /
    retryStmt /
    breakStmt /
    nextStmt /
    yieldStmt /
    aliasStmt /
    beginStmt /
    whileStmt /
    untilStmt /
    forStmt /
    caseStmt /
    singletonClassStmt /
    classStmt /
    moduleStmt /
    defStmt /
    ifStmt /
    unlessStmt /
    rightwardAssignStmt /
    exprStatement
  ) (inlineSpacing modifierSuffix)*
  => { case stmt ~ _ => stmt.asInstanceOf[Statement] } ;

// ── Top-level program ─────────────────────────────────────────────────────

// Matches __END__ followed by anything until EOF (data section)
endDataSection =
  "__END__" !identCont .* => { _ => () } ;

topLevelStatements =
  statementSep* (!(endDataSection) statement (statementSep+ !(endDataSection) statement)*)? statementSep*
  => { v => { val (_ ~ opt) ~ _ = v; opt.asInstanceOf[Option[Any]] match { case None => List.empty[Statement]; case Some(inner) => { val (_ ~ first) ~ rest = inner; first.asInstanceOf[Statement] :: rest.asInstanceOf[List[Any]].map { case _ ~ stmt => stmt.asInstanceOf[Statement] } } } } } ;

program =
  spacing ~> topLevelStatements <~ spacing <~ endDataSection?
  => { stmts => Program(stmts.asInstanceOf[List[Statement]]) } ;
